# Notion Integration Token
NOTION_TOKEN=your_notion_integration_token_here

# Source Notion Page ID (not database)
NOTION_PAGE_ID=your_notion_page_id_here

# Server port (default: 3000)
PORT=3000

# IMPORTANT: If port 3000 is already in use (e.g., by Postgres), use a different port like 3010

# Link enrichment timeout in milliseconds (default: 3000)
LINK_TIMEOUT=3000

# Number of recently served chunks to avoid (default: 10)
HISTORY_SIZE=10
