{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build"
  },
  "deploy": {
    "startCommand": "npm start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100,
    "retryPolicy": {
      "type": "exit",
      "maxRetries": 3,
      "maxRetryDelayMs": 10000
    }
  }
}
